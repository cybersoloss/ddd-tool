{
  "name": "nexus",
  "version": "1.0.0",
  "description": "AI-powered content intelligence platform",
  "private": true,
  "scripts": {
    "dev": "npx tsx watch src/server/index.ts",
    "dev:frontend": "npx next dev --port 3000",
    "dev:worker": "npx tsx watch src/workers/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:frontend\" \"npm run dev:worker\"",
    "build": "tsc -p tsconfig.server.json && next build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:frontend": "next build",
    "start": "node dist/server/index.js",
    "start:frontend": "next start",
    "test": "npx vitest run",
    "test:watch": "npx vitest",
    "test:coverage": "npx vitest run --coverage",
    "lint": "tsc --noEmit",
    "db:setup": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:studio": "npx prisma studio",
    "db:generate": "npx prisma generate"
  },
  "dependencies": {
    "express": "^4.18.0",
    "@prisma/client": "^5.0.0",
    "zod": "^3.22.0",
    "jsonwebtoken": "^9.0.0",
    "bcrypt": "^5.1.0",
    "bullmq": "^5.0.0",
    "ioredis": "^5.3.0",
    "socket.io": "^4.7.0",
    "@anthropic-ai/sdk": "^0.24.0",
    "openai": "^4.0.0",
    "rss-parser": "^3.13.0",
    "cheerio": "^1.0.0",
    "csv-parse": "^5.5.0",
    "fast-xml-parser": "^4.3.0",
    "marked": "^12.0.0",
    "@sendgrid/mail": "^8.1.0",
    "stripe": "^14.0.0",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.2.0",
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0",
    "@tanstack/react-query": "^5.0.0",
    "lucide-react": "^0.400.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.3.0"
  },
  "devDependencies": {
    "vitest": "^1.0.0",
    "supertest": "^6.3.0",
    "typescript": "^5.3.0",
    "prisma": "^5.0.0",
    "tsx": "^4.7.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/bcrypt": "^5.0.0",
    "@types/cors": "^2.8.0",
    "@types/supertest": "^6.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "concurrently": "^8.2.0",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^1.0.0"
  }
}
