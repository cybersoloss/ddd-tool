generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

enum ContentCategory {
  news
  opinion
  research
  other
}

enum ContentStatus {
  draft
  review
  approved
  rejected
  published
  archived
}

enum SourceType {
  rss
  web
  csv
  webhook
  social
  filesystem
}

enum ChannelType {
  website
  twitter
  linkedin
  newsletter
  webhook
}

enum UserPlan {
  free
  pro
  enterprise
}

enum RuleType {
  ingestion
  routing
  publishing
}

enum PublishStatus {
  pending
  success
  failed
}

enum ScheduleStatus {
  pending
  executed
  cancelled
}

// ──────────────────────────────────────────────
// Models
// ──────────────────────────────────────────────

model Role {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  name        String   @unique @db.VarChar(50)
  permissions Json

  users User[]

  @@index([name])
  @@map("roles")
}

model User {
  id           String    @id @default(uuid())
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  email        String    @unique @db.VarChar(255)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  roleId       String    @map("role_id")
  apiKeyHash   String?   @map("api_key_hash")
  plan         UserPlan  @default(free)
  deletedAt    DateTime? @map("deleted_at")

  role          Role            @relation(fields: [roleId], references: [id])
  apiKeys       ApiKey[]
  notifications Notification[]
  profile       UserProfile?
  versions      ContentVersion[] @relation("VersionAuthor")
  rejections    ContentRejection[] @relation("RejectionReviewer")

  @@index([email])
  @@index([roleId])
  @@index([deletedAt])
  @@map("users")
}

model UserProfile {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  userId      String   @unique @map("user_id")
  displayName String?  @map("display_name") @db.VarChar(100)
  avatarUrl   String?  @map("avatar_url")
  bio         String?  @db.Text
  timezone    String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("user_profiles")
}

model ApiKey {
  id         String    @id @default(uuid())
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  userId     String    @map("user_id")
  keyHash    String    @map("key_hash")
  name       String    @db.VarChar(100)
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")
  status     String    @default("active") @db.VarChar(20)
  scopes     Json      @default("[]")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("api_keys")
}

model ContentSource {
  id           String     @id @default(uuid())
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  type         SourceType
  name         String     @db.VarChar(200)
  url          String?
  config       Json       @default("{}")
  lastSyncedAt DateTime?  @map("last_synced_at")
  enabled      Boolean    @default(true)

  contents Content[]

  @@index([type])
  @@index([enabled])
  @@map("content_sources")
}

model Content {
  id           String        @id @default(uuid())
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  title        String        @db.VarChar(500)
  body         String        @db.Text
  summary      String?       @db.Text
  category     ContentCategory
  status       ContentStatus @default(draft)
  qualityScore Decimal?      @map("quality_score")
  biasScore    Decimal?      @map("bias_score")
  sourceType   String        @map("source_type")
  sourceId     String?       @map("source_id")
  metadata     Json?
  deletedAt    DateTime?     @map("deleted_at")

  source         ContentSource?     @relation(fields: [sourceId], references: [id])
  versions       ContentVersion[]
  rejections     ContentRejection[]
  publishRecords PublishRecord[]
  schedules      Schedule[]

  @@unique([sourceType, sourceId])
  @@index([status, createdAt])
  @@index([deletedAt])
  @@map("contents")
}

model ContentVersion {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  contentId     String   @map("content_id")
  bodySnapshot  String   @map("body_snapshot") @db.Text
  changedBy     String   @map("changed_by")
  changeSummary String?  @map("change_summary") @db.VarChar(500)
  changedAt     DateTime @map("changed_at")

  content Content @relation(fields: [contentId], references: [id])
  author  User    @relation("VersionAuthor", fields: [changedBy], references: [id])

  @@index([contentId, changedAt])
  @@map("content_versions")
}

model ContentRejection {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  contentId   String   @map("content_id")
  reason      String   @db.Text
  rejectedBy  String   @map("rejected_by")
  rejectedAt  DateTime @map("rejected_at")

  content  Content @relation(fields: [contentId], references: [id])
  reviewer User    @relation("RejectionReviewer", fields: [rejectedBy], references: [id])

  @@index([contentId])
  @@map("content_rejections")
}

model Channel {
  id        String      @id @default(uuid())
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  name      String      @unique @db.VarChar(100)
  type      ChannelType
  config    Json        @default("{}")
  enabled   Boolean     @default(true)

  publishRecords PublishRecord[]
  schedules      Schedule[]

  @@index([name])
  @@map("channels")
}

model PublishRecord {
  id          String        @id @default(uuid())
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  contentId   String        @map("content_id")
  channelId   String        @map("channel_id")
  status      PublishStatus @default(pending)
  publishedAt DateTime?     @map("published_at")
  error       String?
  attempts    Int           @default(0)

  content Content @relation(fields: [contentId], references: [id])
  channel Channel @relation(fields: [channelId], references: [id])

  @@index([contentId, channelId])
  @@index([status])
  @@map("publish_records")
}

model Schedule {
  id          String         @id @default(uuid())
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  contentId   String         @map("content_id")
  channelId   String         @map("channel_id")
  publishAt   DateTime       @map("publish_at")
  createdBy   String         @map("created_by")
  status      ScheduleStatus @default(pending)

  content Content @relation(fields: [contentId], references: [id])
  channel Channel @relation(fields: [channelId], references: [id])

  @@index([publishAt])
  @@index([status, publishAt])
  @@map("schedules")
}

model AnalyticsEvent {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  eventType   String   @map("event_type") @db.VarChar(100)
  entityId    String?  @map("entity_id")
  entityType  String?  @map("entity_type") @db.VarChar(50)
  actorId     String?  @map("actor_id")
  metadata    Json?
  occurredAt  DateTime @map("occurred_at")
  metricName  String?  @map("metric_name") @db.VarChar(100)
  windowStart DateTime? @map("window_start")

  @@index([eventType, occurredAt])
  @@index([entityId])
  @@map("analytics_events")
}

model Notification {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  userId    String   @map("user_id")
  type      String   @db.VarChar(50)
  title     String   @db.VarChar(200)
  body      String   @db.Text
  read      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@index([createdAt])
  @@map("notifications")
}

model Setting {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  key       String   @unique @db.VarChar(100)
  value     Json

  @@index([key])
  @@map("settings")
}

model Rule {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  type      RuleType
  condition Json
  action    Json
  priority  Int      @default(0)
  enabled   Boolean  @default(true)
  name      String   @default("") @db.VarChar(200)
  children  Json     @default("[]")

  @@index([type, enabled, priority])
  @@map("rules")
}

model WeeklyDigest {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  stats       Json
  generatedAt DateTime @map("generated_at")

  @@index([periodStart, periodEnd])
  @@map("weekly_digests")
}
