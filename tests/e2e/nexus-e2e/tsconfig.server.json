{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/server/**/*", "src/workers/**/*", "src/config/**/*", "src/errors/**/*", "src/middleware/**/*", "src/routes/**/*", "src/services/**/*", "src/repositories/**/*", "src/utils/**/*", "src/types/**/*", "src/lib/**/*", "src/agents/**/*"],
  "exclude": ["src/app/**/*", "src/components/**/*", "src/stores/**/*", "node_modules"]
}
