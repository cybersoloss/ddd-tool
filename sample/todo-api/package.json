{
  "name": "todo-api",
  "version": "0.1.0",
  "description": "Simple Todo REST API",
  "scripts": {
    "dev": "npx tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "npx jest",
    "lint": "npx tsc --noEmit",
    "db:setup": "npx prisma generate && npx prisma db push",
    "db:seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "@prisma/client": "^5.10.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "tsx": "^4.7.1",
    "prisma": "^5.10.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.2",
    "supertest": "^6.3.4",
    "@types/supertest": "^6.0.2"
  }
}
